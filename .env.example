# =============================================================================
# Estuary CDC demo configuration.
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
#
#   cp .env.example .env
# =============================================================================

# ----- AWS -------------------------------------------------------------------
# Region for the RDS instance. This is INDEPENDENT of your Estuary data plane
# (the capture allowlist IPs come from the data plane, not this region).
AWS_REGION=us-west-2
# If you authenticate with a named profile (e.g. AWS IAM Identity Center / SSO),
# set it here so Terraform uses it. Leave blank for default-chain credentials.
# With SSO, refresh the session first:  aws sso login --profile <name>
# Also ensure no stale AWS_ACCESS_KEY_ID/AWS_SESSION_TOKEN env vars are set, as
# those override AWS_PROFILE.
AWS_PROFILE=
# Your public IP in CIDR notation, for psql/admin access. OPTIONAL: leave blank
# and start.sh auto-detects this machine's public IPv4 and allowlists it as /32.
# Set it explicitly to override — e.g. to pin a static range or add several IPs.
# This is ADDITIVE: your IP is added ON TOP OF Estuary's data-plane IPs (which
# the capture connects from) — it never overrides them. Paste one CIDR, or a
# comma-separated list for several of your own IPs, e.g.
#   TF_VAR_allowed_cidr=1.2.3.4/32
#   TF_VAR_allowed_cidr=1.2.3.4/32,5.6.7.8/32
# Estuary's egress IPs default to the public GCP us-central1 data plane in
# terraform/variables.tf. They depend on your DATA PLANE, not AWS_REGION. Get
# the exact list from Admin -> "Allowlist IP addresses" in your dashboard:
#   export TF_VAR_estuary_cidrs='["35.226.75.135/32"]'
TF_VAR_allowed_cidr=          # e.g. 1.2.3.4/32

# ----- Postgres --------------------------------------------------------------
# These are POPULATED AUTOMATICALLY from Terraform outputs by scripts/start.sh.
# Leave them blank; they're listed here for reference (the password is generated
# by Terraform and never stored in this file).
PGHOST=
PGPORT=5432
PGDATABASE=demo
PGUSER=flowdemo
PGPASSWORD=

# ----- ShadowTraffic ---------------------------------------------------------
# ShadowTraffic is licensed via a separate file of license variables, NOT a
# single key. Copy shadowtraffic/license.env.example to shadowtraffic/license.env
# and paste in your (free) license from https://shadowtraffic.io/pricing.html
# See shadowtraffic/license.env.example for the exact variables.

# ----- Estuary ---------------------------------------------------------------
# Refresh/CLI token from the Estuary dashboard: Admin -> CLI-API -> Generate token.
ESTUARY_TOKEN=
# Your tenant prefix plus a demo namespace. All Flow tasks live under this.
ESTUARY_PREFIX=               # e.g. yourTenant/estuary-cdc-demo

# ----- Snowflake -------------------------------------------------------------
# Account identifier in org-account form, e.g. abcd-xy12345 (no .snowflakecomputing.com).
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
# Key-pair (JWT) auth. Path to the unencrypted PKCS#8 private key (.p8) whose
# PUBLIC key is assigned to SNOWFLAKE_USER. See the README for generation steps.
SNOWFLAKE_PRIVATE_KEY_PATH=./secrets/rsa_key.p8
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
# Base schema name. The scripts make the effective schema unique per Estuary
# tenant by appending a token from ESTUARY_PREFIX (e.g. estuary_cdc_demo_wassdemo),
# so recycling to a fresh tenant never collides with leftover tables. All demo
# tables land in that one schema; teardown drops it CASCADE.
SNOWFLAKE_SCHEMA=estuary_cdc_demo
